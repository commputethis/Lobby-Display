#!/bin/bash

APP_DIR="$(dirname "$(readlink -f "$0")")"

# Detect Python version
PYTHON_VERSION=$(python3 --version | cut -d' ' -f2 | cut -d'.' -f1,2)  # e.g., "3.13"
PYTHON_MAJOR=$(echo $PYTHON_VERSION | cut -d'.' -f1)  # e.g., "3"

export PATH="$APP_DIR/usr/bin:$PATH"
export PYTHONPATH="$APP_DIR/usr/lib:$APP_DIR/usr/lib/python${PYTHON_VERSION}/site-packages:$APP_DIR/usr/lib/python${PYTHON_MAJOR}/dist-packages:$PYTHONPATH"
export LD_LIBRARY_PATH="$APP_DIR/usr/lib:$LD_LIBRARY_PATH"

DATA_DIR="/opt/lobby-display"
CURRENT_USER=$(whoami)
CURRENT_USER_GROUP=$(id -gn)

if [ "$1" == "--install" ]; then
    echo "Installing Lobby Display..."
    
    sudo mkdir -p "$DATA_DIR"/{uploads,config}
    sudo cp "$APP_DIR"/usr/share/lobby-display/*.py "$DATA_DIR/" 2>/dev/null || true
    sudo cp -r "$APP_DIR"/usr/share/lobby-display/templates "$DATA_DIR/" 2>/dev/null || true
    sudo cp -r "$APP_DIR"/usr/share/lobby-display/static "$DATA_DIR/" 2>/dev/null || true
    
    # Use detected user instead of hardcoded 'pi'
    sudo chown -R "$CURRENT_USER:$CURRENT_USER_GROUP" "$DATA_DIR"
    
    echo "$APPIMAGE" | sudo tee "$DATA_DIR/.appimage-path" > /dev/null
    
    # Create web service with detected user
    sudo tee /etc/systemd/system/lobby-web.service > /dev/null << EOF
[Unit]
Description=Lobby Display Web
After=network.target

[Service]
Type=simple
User=$CURRENT_USER
WorkingDirectory=$DATA_DIR
Environment="LOBBY_DATA_DIR=$DATA_DIR"
Environment="PYTHONUNBUFFERED=1"
ExecStart=$APPIMAGE --web
Restart=always

[Install]
WantedBy=multi-user.target
EOF

    # Create display service with detected user
    sudo tee /etc/systemd/system/lobby-display.service > /dev/null << EOF
[Unit]
Description=Lobby Display Slideshow
After=network.target lobby-web.service

[Service]
Type=simple
User=$CURRENT_USER
Environment="DISPLAY=:0"
Environment="XAUTHORITY=/home/$CURRENT_USER/.Xauthority"
Environment="LOBBY_DATA_DIR=$DATA_DIR"
ExecStart=$APPIMAGE --display
Restart=always

[Install]
WantedBy=multi-user.target
EOF

    sudo systemctl daemon-reload
    sudo systemctl enable lobby-web lobby-display
    
    echo ""
    echo "Installed for user: $CURRENT_USER"
    echo "Start with: sudo systemctl start lobby-web lobby-display"
    echo "Web interface: http://$(hostname -I | awk '{print $1}'):5000"
    exit 0
fi

if [ "$1" == "--web" ]; then
    export LOBBY_DATA_DIR="$DATA_DIR"
    exec "$APP_DIR/usr/bin/python3" "$APP_DIR/usr/share/lobby-display/app.py"
    exit 0
fi

if [ "$1" == "--display" ]; then
    export LOBBY_DATA_DIR="$DATA_DIR"
    exec "$APP_DIR/usr/bin/python3" "$APP_DIR/usr/share/lobby-display/display.py"
    exit 0
fi

if [ ! -d "$DATA_DIR" ]; then
    echo "First run. Installing services..."
    exec "$0" --install
    exit 0
fi

echo "Lobby Display (running as: $CURRENT_USER)"
echo "============="
systemctl is-active lobby-web >/dev/null 2>&1 && echo "Web:     RUNNING" || echo "Web:     STOPPED"
systemctl is-active lobby-display >/dev/null 2>&1 && echo "Display: RUNNING" || echo "Display: STOPPED"
echo ""
echo "Web interface: http://$(hostname -I | awk '{print $1}'):5000"
echo ""
echo "Commands:"
echo "  $APPIMAGE --install  # Install/reinstall"
echo "  $APPIMAGE --web      # Run web server (foreground)"
echo "  $APPIMAGE --display  # Run display (foreground)"